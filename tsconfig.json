{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./src/shared/*"],
      "@constant/*": ["./src/shared/constants/*"],
      "@enums/*": ["./src/shared/enums/*"],
      "@hooks/*": ["./src/shared/hooks/*"],
      "@utils/*": ["./src/shared/utils/*"],
      "@components/*": ["src/shared/components/*"],
      "@layouts/*": ["src/shared/layouts/*"],
      "@pages/*": ["./src/pages/*"]
    }
  }
}
